# ============================================
#  PYTHON / DJANGO
# ============================================

# Entornos virtuales
venv/
env/
env2/
.env/
.venv/

# Archivos de configuración sensibles
*.env
*.env.local
*.env.dev
*.env.prod

# Bytecode y cachés
__pycache__/
*.py[cod]
*$py.class
.pytest_cache

# Archivos temporales
*.log
*.pot
*.pyc
*.pyo
*.pyd

# Archivos de bases de datos locales
db.sqlite3
*.db

# Archivos de compilación / cobertura
*.cover
*.coverage
*.tox
.coverage
nosetests.xml
coverage.xml
*.mo

# Archivos generados por Django
/staticfiles/
media/
*.pid

# ============================================
# NODE / VITE
# ============================================

# Dependencias
node_modules/

# Builds (Vite usa dist/ por defecto)
dist/
dist-ssr/
*.local

# Archivos de lock de dependencias
package-lock.json
yarn.lock
pnpm-lock.yaml

# Variables de entorno
.env.local
.env.development.local
.env.test.local
.env.production.local

# Archivos temporales
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# DOCKER
# ============================================

# Volúmenes persistentes locales
volumes/
postgres_data/
*/postgres_data/

# Archivos de build locales
*.pid
*.tar
*.bak
*.old
*.orig

# Docker Compose override local
docker-compose.override.yml

# ============================================
#  PRODUCTION / SECURITY
# ============================================

# Certificados y claves (Zero-Checkin Policy)
*.pem
*.key
*.crt
*.cer
ssl/
certs/

# Archivos de Secrets Manager (si se usa Vault, AWS Secrets, etc.)
secrets.json
credentials.json
*.secret

# ============================================
#  IDEs / SISTEMA
# ============================================

# VSCode
.vscode/
.history/
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# ============================================
# ESTS / TEMP
# ============================================

# Carpeta de pytest / coverage
htmlcov/
.cache/
pytest_cache/

# Archivos temporales y backups
*.swp
*.swo
*.bak
*.tmp
*.temp

# Archivos de log
.github/
/myenv
/staticfiles

# Archivos multimedia
*.mp4
avatars/
performance/